    <string name="message_notification_title">Allow Battery Notifications</string>
    <string name="message_notification_description">For Batty to send you important alerts about your battery status (ex., low battery, full charge) and display a persistent notification with real-time information, we need your permission to send notifications. Don\'t run out of battery without knowing!</string>
    <string name="message_notification_route">If you don\'t see the permission request, you can enable them manually in: Settings > Apps > Batty > Notifications.</string>
    <string name="message_dnd_title">Allow Battery Notifications in Do Not Disturb Mode</string>
    <string name="message_dnd_description">For Batty to send you important alerts about your battery status (ex., low battery, full charge) while you\'re playing, we need your permission to send notifications in Do Not Disturb mode.</string>
    <string name="message_dnd_route">If you don\'t see the request, you can activate it manually in: Settings > Apps > [Your App] > Permissions > Special app access > Do Not Disturb access.</string>

